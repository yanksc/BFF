# --- Database (Neon / Vercel Postgres) ---
# Auto-provisioned when you attach a Neon store via Vercel's Storage tab.
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# --- Vercel Blob (durable selfie image storage) ---
# Auto-provisioned when you create a PUBLIC Blob store in the Vercel dashboard.
# Note: the code uses `access: 'public'` — do NOT use a private store.
BLOB_READ_WRITE_TOKEN=

# --- Session cookie (iron-session) ---
# 32+ random characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_PASSWORD=

# --- Cron auth ---
# 32+ random characters. Used to authenticate /api/cron/daily calls from Vercel Cron.
CRON_SECRET=

# --- Vercel AI Gateway (text generation) ---
# Get this from: Vercel Dashboard → AI → Gateway → API Keys
AI_GATEWAY_KEY=

# --- xAI (image generation for selfies) ---
# Get this from: https://console.x.ai/ → API Keys
XAI_API_KEY=
